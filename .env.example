# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키를 입력하세요.
# Windows: copy .env.example .env

# ── Supabase ──
# Project URL (Supabase 대시보드 > Project Settings > API)
SUPABASE_URL=https://lycdpuujujkfxyctkyuu.supabase.co

# Public Key — 브라우저(프론트엔드)에서 사용
SUPABASE_PUBLIC_KEY=

# Secret Key — 서버 전용. 절대 프론트엔드에 노출하지 마세요.
SUPABASE_SECRET_KEY=

# ── 검색 · AI API (서버 전용, api/*.js 에서만 사용) ──

# Tavily — https://app.tavily.com/
TAVILY_API_KEY=

# Naver 검색 API — https://developers.naver.com/apps/#/list
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Kakao — 카카오톡 나에게 보내기 ──
# 개발자 콘솔: https://developers.kakao.com/console/app
# 제품 설정 > 카카오 로그인 ON + Redirect URI 등록
# 제품 설정 > 카카오톡 메시지 > 「나에게 보내기」 ON
# 동의 항목: talk_message (카카오톡 메시지 전송)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# 배포 주소 (보고서 상세 링크·OAuth 기준) — 배포 URL 1개
# 예: https://report-creator.vercel.app
APP_PUBLIC_URL=

# Redirect URI — 카카오 콘솔에 등록할 배포용 주소 1개
# 예: https://report-creator.vercel.app/api/kakao/oauth/callback
KAKAO_REDIRECT_URI=

# OAuth 1회 로그인 (/api/kakao/oauth/login) 후 발급
# Vercel: Environment Variables에 등록 후 재배포
KAKAO_REFRESH_TOKEN=

# ── 로컬 개발 ──
# npm install && npm run dev  → http://localhost:3000
