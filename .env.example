# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키를 입력하세요.
# Windows: copy .env.example .env

# ── Supabase ──
# Project URL (Supabase 대시보드 > Project Settings > API)
SUPABASE_URL=https://lycdpuujujkfxyctkyuu.supabase.co

# Public Key — 브라우저(프론트엔드)에서 사용
SUPABASE_PUBLIC_KEY=

# Secret Key — 서버 전용. 절대 프론트엔드에 노출하지 마세요.
SUPABASE_SECRET_KEY=

# ── 검색 · AI API (서버 전용, api/*.js 에서만 사용) ──

# Tavily — https://app.tavily.com/
TAVILY_API_KEY=

# Naver 검색 API — https://developers.naver.com/apps/#/list
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── 로컬 개발 (Vercel dev) ──
# 1. copy .env.example .env  후 위 키 입력
# 2. npm install
# 3. npm run dev  → http://localhost:3000 (Vercel과 동일 Serverless 환경)
# 4. 확인: http://localhost:3000/api/health
